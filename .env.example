# ============================================
# Supabase（Day 2 需要）
# 从 https://supabase.com/dashboard 项目 Settings > API 获取
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# ============================================
# Cloudflare R2（Day 2 需要）
# 从 https://dash.cloudflare.com > R2 获取
# ============================================
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=ai-tattoo-generator
R2_PUBLIC_URL=https://tattoo-images.yourdomain.com

# ============================================
# Kie.ai 中转（Day 3 需要）
# 用于调用 OpenAI gpt-image-2，避开国内直连 OpenAI 的风险
# API Key: https://kie.ai/api-key
# 文档:   docs/kie-ai-api.md
# ============================================
KIE_API_KEY=sk-xxx
KIE_BASE_URL=https://api.kie.ai

